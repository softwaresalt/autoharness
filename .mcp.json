{
  "mcpServers": {
    "backlogit": {
      "type": "stdio",
      "command": "backlogit",
      "args": ["mcp"],
      "env": {"BACKLOGIT_WORKSPACE": "${workspace_folder}"},
      "tools": ["*"]
    },
    "engram": {
      "type": "stdio",
      "command": "engram",
      "args": ["shim"],
      "env": {"ENGRAM_WORKSPACE": "${workspace_folder}"},
      "tools": ["*"]
    },
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": ["@upstash/context7-mcp"],
      "tools": ["*"]
    },
    "tavily": {
      "type": "stdio",
      "command": "bunx",
      "args": ["tavily-mcp"],
      "tools": ["*"]
    },
    "github": {
      "type": "stdio",
      "command": "github-mcp-server.exe",
      "args": ["stdio"],
      "tools": ["*"]
    }
  }
}
