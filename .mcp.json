{
  "mcpServers": {
    "backlogit": {
      "type": "stdio",
      "command": "backlogit",
      "args": ["mcp"],
      "env": {
        "BACKLOGIT_WORKSPACE": "${workspace_folder}"
      },
      "tools": ["*"]
    },
    "engram": {
      "type": "stdio",
      "command": "engram",
      "args": ["shim"],
      "env": {
        "ENGRAM_WORKSPACE": "${workspace_folder}"
      },
      "tools": ["*"]
    },
    "graphtor-docs": {
      "type": "stdio",
      "command": "graphtor-docs",
      "args": ["serve"],
      "env": {
        "GRAPHTOR_DB_PATH": "${workspace_folder}/.graphtor/graph.db",
        "GRAPHTOR_SOURCES": "${workspace_folder}/.graphtor/config/sources.yaml"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": ["--bun", "@upstash/context7-mcp"],
      "tools": ["*"]
    },
    "tavily": {
      "type": "stdio",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "if ([string]::IsNullOrWhiteSpace($env:TAVILY_API_KEY)) { throw 'TAVILY_API_KEY is not set.' }; bunx tavily-mcp@latest"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "$env:GITHUB_PERSONAL_ACCESS_TOKEN = (gh auth token); bunx --bun @modelcontextprotocol/server-github"
      ],
      "tools": ["*"]
    }
  }
}
