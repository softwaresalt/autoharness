{
  "mcpServers": {
    "backlogit": {
      "type": "stdio",
      "command": "backlogit",
      "args": ["mcp"],
      "env": {
        "BACKLOGIT_WORKSPACE": "${workspaceFolder}"
      },
      "tools": ["*"]
    },
    "engram": {
      "type": "stdio",
      "command": "engram",
      "args": ["shim"],
      "env": {
        "ENGRAM_WORKSPACE": "${workspaceFolder}"
      }
    },
    "graphtor-docs": {
      "type": "stdio",
      "command": "graphtor-docs",
      "args": ["serve"],
      "tools": ["*"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "tools": ["*"]
    },
    "tavily": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tavily-mcp@latest"]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "tools": ["*"]
    }
  }
}
