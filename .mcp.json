{
  "mcpServers": {
    "backlogit": {
      "type": "stdio",
      "command": "backlogit",
      "args": ["mcp"],
      "env": {
        "BACKLOGIT_WORKSPACE": "C:\\Source\\GitHub\\autoharness"
      },
      "tools": ["*"]
    },
    "engram": {
      "type": "stdio",
      "command": "engram",
      "args": ["shim"],
      "env": {
        "ENGRAM_WORKSPACE": "C:\\Source\\GitHub\\autoharness"
      }
    },
    "graphtor-docs": {
      "type": "stdio",
      "command": "graphtor-docs",
      "args": ["serve"],
      "tools": ["*"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "tools": ["*"]
    },
    "tavily": {
      "type": "stdio",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "if ([string]::IsNullOrWhiteSpace($env:TAVILY_API_KEY)) { throw 'TAVILY_API_KEY is not set.' }; npx -y tavily-mcp@latest"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "tools": ["*"]
    }
  }
}
