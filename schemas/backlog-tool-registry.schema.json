{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Backlog Tool Registry",
  "description": "Schema for registering a backlog management tool with the autoharness framework. Provides the abstraction layer between harness agents and the specific backlog tool installed in the workspace.",
  "type": "object",
  "required": ["schema_version", "tool_name", "tool_type", "directory", "operations"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "tool_name": {
      "type": "string",
      "description": "Human-readable name of the backlog tool",
      "examples": ["backlogit", "backlog-md"]
    },
    "tool_type": {
      "type": "string",
      "enum": ["mcp", "cli", "both"],
      "description": "How the tool is accessed: MCP server, CLI, or both"
    },
    "directory": {
      "type": "string",
      "description": "Root directory for backlog files relative to workspace root",
      "examples": [".backlogit", "backlog"]
    },
    "mcp_server": {
      "type": "object",
      "description": "MCP server configuration (required when tool_type is 'mcp' or 'both')",
      "properties": {
        "command": {
          "type": "string",
          "description": "Command to start the MCP server",
          "examples": ["backlogit mcp", "npx backlog-md mcp"]
        },
        "transport": {
          "type": "string",
          "enum": ["stdio", "sse", "http", "streamable-http"],
          "default": "stdio"
        }
      }
    },
    "cli": {
      "type": "object",
      "description": "CLI configuration (required when tool_type is 'cli' or 'both')",
      "properties": {
        "binary": {
          "type": "string",
          "description": "CLI binary name",
          "examples": ["backlogit", "backlog"]
        }
      }
    },
    "operations": {
      "type": "object",
      "description": "Maps abstract harness operations to tool-specific commands. Each operation maps to either an MCP tool name or CLI command.",
      "required": ["create_task", "list_tasks", "get_task", "update_task", "move_task"],
      "properties": {
        "create_task": { "$ref": "#/$defs/operation" },
        "list_tasks": { "$ref": "#/$defs/operation" },
        "get_task": { "$ref": "#/$defs/operation" },
        "update_task": { "$ref": "#/$defs/operation" },
        "move_task": { "$ref": "#/$defs/operation" },
        "delete_task": { "$ref": "#/$defs/operation" },
        "search_tasks": { "$ref": "#/$defs/operation" },
        "complete_task": { "$ref": "#/$defs/operation" },
        "query": { "$ref": "#/$defs/operation" },
        "sync_index": { "$ref": "#/$defs/operation" },
        "append_comment": { "$ref": "#/$defs/operation" },
        "log_telemetry": { "$ref": "#/$defs/operation" },
        "save_memory": { "$ref": "#/$defs/operation" },
        "create_checkpoint": { "$ref": "#/$defs/operation" },
          "list_checkpoints": { "$ref": "#/$defs/operation" },
          "get_checkpoint": { "$ref": "#/$defs/operation" },
          "resolve_checkpoint": { "$ref": "#/$defs/operation" },
          "poll_hook_events": { "$ref": "#/$defs/operation" },
          "ack_hook_events": { "$ref": "#/$defs/operation" },
        "get_queue": { "$ref": "#/$defs/operation" },
        "add_dependency": { "$ref": "#/$defs/operation" },
        "remove_dependency": { "$ref": "#/$defs/operation" },
        "get_dependencies": { "$ref": "#/$defs/operation" },
        "track_commit": { "$ref": "#/$defs/operation" },
        "list_milestones": { "$ref": "#/$defs/operation" },
        "add_milestone": { "$ref": "#/$defs/operation" },
        "create_shipment": { "$ref": "#/$defs/operation" },
        "get_shipment": { "$ref": "#/$defs/operation" },
        "list_shipments": { "$ref": "#/$defs/operation" },
        "claim_shipment": { "$ref": "#/$defs/operation" },
        "ship_shipment": { "$ref": "#/$defs/operation" },
        "add_to_shipment": { "$ref": "#/$defs/operation" },
        "return_blocked": { "$ref": "#/$defs/operation" }
      }
    },
    "field_mapping": {
      "type": "object",
      "description": "Maps abstract field names to tool-specific parameter names",
      "properties": {
        "task_id": { "type": "string", "default": "id" },
        "title": { "type": "string", "default": "title" },
        "status": { "type": "string", "default": "status" },
        "description": { "type": "string", "default": "description" },
        "parent_id": { "type": "string", "default": "parent_id" },
        "labels": { "type": "string", "default": "labels" },
        "assignee": { "type": "string", "default": "assigned_to" },
        "priority": { "type": "string", "default": "priority" },
        "artifact_type": { "type": "string", "default": "artifact_type" }
      }
    },
    "status_values": {
      "type": "object",
      "description": "Maps abstract status names to tool-specific status strings",
      "properties": {
        "queued": { "type": "string", "default": "queued" },
        "active": { "type": "string", "default": "active" },
        "done": { "type": "string", "default": "done" },
        "blocked": { "type": "string", "default": "blocked" }
      }
    },
    "features": {
      "type": "object",
      "description": "Capabilities the tool supports beyond the core operations",
      "properties": {
        "sql_query": { "type": "boolean", "default": false },
        "milestones": { "type": "boolean", "default": false },
        "documents": { "type": "boolean", "default": false },
        "telemetry": { "type": "boolean", "default": false },
        "memory": { "type": "boolean", "default": false },
        "checkpoints": { "type": "boolean", "default": false },
        "comments": { "type": "boolean", "default": false },
        "definition_of_done": { "type": "boolean", "default": false },
        "workflow_guides": { "type": "boolean", "default": false },
        "dependencies": { "type": "boolean", "default": false },
        "queue": { "type": "boolean", "default": false },
        "sections": { "type": "boolean", "default": false },
        "templates": { "type": "boolean", "default": false },
        "commit_tracking": { "type": "boolean", "default": false },
        "shipments": { "type": "boolean", "default": false }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "tool_type": { "enum": ["mcp", "both"] } }
      },
      "then": {
        "required": ["mcp_server"],
        "properties": {
          "mcp_server": { "required": ["command"] }
        }
      }
    },
    {
      "if": {
        "properties": { "tool_type": { "enum": ["cli", "both"] } }
      },
      "then": {
        "required": ["cli"],
        "properties": {
          "cli": { "required": ["binary"] }
        }
      }
    },
    {
      "if": {
        "required": ["features"],
        "properties": { "features": { "required": ["shipments"], "properties": { "shipments": { "const": true } } } }
      },
      "then": {
        "properties": {
          "operations": {
            "required": ["create_shipment", "get_shipment", "list_shipments", "claim_shipment", "ship_shipment", "add_to_shipment", "return_blocked"]
          }
        }
      }
    }
  ],
  "$defs": {
    "operation": {
      "type": "object",
      "description": "At least one of mcp_tool or cli_command must be provided",
      "anyOf": [
        { "required": ["mcp_tool"] },
        { "required": ["cli_command"] }
      ],
      "properties": {
        "mcp_tool": {
          "type": "string",
          "description": "MCP tool name to call for this operation"
        },
        "cli_command": {
          "type": "string",
          "description": "CLI command to run for this operation"
        },
        "params": {
          "type": "object",
          "description": "Parameter name mapping from abstract to tool-specific",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
