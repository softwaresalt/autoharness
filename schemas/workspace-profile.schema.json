{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workspace Profile",
  "description": "Schema for the workspace profile generated by the workspace-discovery skill",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "workspace_path",
    "languages",
    "build",
    "test"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace_path": {
      "type": "string"
    },
    "languages": {
      "type": "object",
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "description": "The primary programming language of the workspace"
        },
        "version": {
          "type": [
            "string",
            "null"
          ],
          "description": "Language version or edition detected from toolchain config (e.g., rust-toolchain.toml, package.json engines, .python-version)"
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "frameworks": {
      "type": "object",
      "description": "Detected frameworks and specialized SDK integrations",
      "properties": {
        "list": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of detected frameworks (e.g., React, FastAPI, Cobra)"
        },
        "mcp_sdk": {
          "type": [
            "string",
            "null"
          ],
          "description": "MCP SDK detected in dependencies (e.g., mcp-go, @modelcontextprotocol/sdk, mcp)"
        },
        "mcp_transport": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "stdio",
            "sse",
            "streamable-http",
            null
          ],
          "description": "MCP transport mechanism detected when MCP SDK is present"
        }
      }
    },
    "primary_stack_pack": {
      "type": [
        "string",
        "null"
      ],
      "description": "Primary normalized stack classification chosen from detected additive stack packs (for example web-app, api-service, background-worker, mcp-server, cli-tool, or library)"
    },
    "stack_packs": {
      "type": "array",
      "description": "Additive normalized stack classifications detected in the workspace and used to refine preset, layer, and overlay recommendations",
      "items": {
        "type": "string"
      }
    },
    "build": {
      "type": "object",
      "required": [
        "tool",
        "command"
      ],
      "properties": {
        "tool": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "check_command": {
          "type": [
            "string",
            "null"
          ],
          "description": "Fast compilation-only check command (no tests). Defaults to build.command if null. E.g., cargo check --all-targets, tsc --noEmit."
        }
      }
    },
    "test": {
      "type": "object",
      "required": [
        "runner",
        "command"
      ],
      "properties": {
        "runner": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "directory": {
          "type": "string"
        }
      }
    },
    "lint": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string"
        },
        "command": {
          "type": "string"
        }
      }
    },
    "typecheck": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string"
        },
        "command": {
          "type": [
            "string",
            "null"
          ],
          "description": "Read-only static type-check command (exits non-zero on type errors), e.g. tsc --noEmit or mypy src/. Null when the workspace has no typecheck gate."
        }
      }
    },
    "format": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "check_command": {
          "type": [
            "string",
            "null"
          ],
          "description": "Read-only format check command (exits non-zero if formatting needed). Defaults to appending --check to format.command."
        },
        "fix_command": {
          "type": "string"
        }
      }
    },
    "ci": {
      "type": "object",
      "properties": {
        "platform": {
          "type": "string"
        },
        "pipeline_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quality_gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_check_name": {
          "type": "string",
          "description": "Name of the always-running aggregation-gate check (the reported check context, which may contain spaces) that a branch ruleset should require. This is the single required status check; guarded expensive jobs are never the required check so they may be skipped on docs-only PRs without blocking merge. The underlying job ID is always a fixed slug (ci-gate). Default 'ci gate'. Set to match an existing required-check name (e.g. 'build') when one is already configured, so no ruleset edit is needed.",
          "default": "ci gate"
        },
        "linux_only": {
          "type": "boolean",
          "const": true,
          "description": "Always true: regular PR/push CI runs on Linux only (ubuntu-latest). Cross-OS verification is delegated to release-tag workflows; this template does not auto-generate a multi-OS matrix, so the field is constrained to true. Reserved for a future matrix implementation.",
          "default": true
        },
        "path_filter_mode": {
          "type": "string",
          "description": "How CI decides whether the expensive gate runs. Only 'fail_closed_changes_job' is supported: a lightweight always-running detection job using dorny/paths-filter with predicate-quantifier 'every' over a denylist, so any code/config/unknown-type change fails closed into the gate while the always-running aggregation gate still reports a status.",
          "enum": [
            "fail_closed_changes_job"
          ],
          "default": "fail_closed_changes_job"
        },
        "docs_only_paths": {
          "type": "array",
          "description": "Directory/path patterns positively identified as documentation or state that are safe to exclude from the expensive gate (used as denylist negations for the fail-closed changes job). Prefer specific directories (e.g. 'docs/**', '.backlogit/**'). Do NOT use an extension-wide glob such as '**/*.md' when Markdown is executable product in the workspace (e.g. agent/skill/instruction files under '.github/'), since that would let harness changes skip the gate while the aggregation check still reports success. Example: ['docs/**', '.backlogit/**', '.autoharness/**'].",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "local_gating": {
      "type": "object",
      "description": "Configuration for the cross-platform local pre-push quality-gate hook (P-019). The hook runs the discovered build/test/lint/format/typecheck gates before push and blocks the push on failure; it is opt-in and installable.",
      "properties": {
        "pre_push_enabled": {
          "type": "boolean",
          "description": "Whether the pre-push quality-gate hook should be composed for this workspace. The installed hook remains opt-in (activated by an explicit operator step); this flag only controls whether the artifact is generated.",
          "default": true
        },
        "pre_push_gates": {
          "type": "array",
          "description": "Ordered list of quality gates the pre-push hook runs. Each gate names a discovered command (resolved from build/test/lint/format/typecheck profile fields). Absent gates are skipped (tool-not-found -> warn and skip), not failed.",
          "items": {
            "type": "string",
            "enum": [
              "test",
              "lint",
              "format",
              "typecheck",
              "build"
            ]
          }
        }
      }
    },
    "structure": {
      "type": "object",
      "properties": {
        "source_layout": {
          "type": "string"
        },
        "test_layout": {
          "type": "string"
        },
        "doc_layout": {
          "type": "string"
        }
      }
    },
    "runtime_surfaces": {
      "type": "object",
      "description": "Runtime surfaces that may require post-build verification and operational closure",
      "properties": {
        "cli": {
          "type": "boolean"
        },
        "web_ui": {
          "type": "boolean"
        },
        "public_api": {
          "type": "boolean"
        },
        "background_jobs": {
          "type": "boolean"
        },
        "browser_tooling": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Detected browser automation or browser QA tooling relevant to runtime verification"
        },
        "deployment_manifests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runtime_validation": {
      "type": "object",
      "description": "Structured runtime validator contract produced by workspace discovery and consumed by Ship, runtime-verification, and operational-closure workflows.",
      "properties": {
        "validator_manifest": {
          "type": "object",
          "required": [
            "surfaces"
          ],
          "properties": {
            "surfaces": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "surface",
                  "adapter_hint",
                  "probe_hints",
                  "manual_checkpoints"
                ],
                "properties": {
                  "surface": {
                    "type": "string",
                    "enum": [
                      "cli",
                      "api",
                      "browser",
                      "background-job"
                    ],
                    "description": "Runtime surface covered by this validator entry."
                  },
                  "adapter_hint": {
                    "type": "string",
                    "enum": [
                      "auto",
                      "command",
                      "http",
                      "browser",
                      "job",
                      "manual"
                    ],
                    "description": "Preferred execution adapter for this runtime surface."
                  },
                  "probe_hints": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "id",
                        "kind",
                        "target",
                        "required",
                        "evidence_types"
                      ],
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "kind": {
                          "type": "string",
                          "enum": [
                            "command",
                            "http-request",
                            "browser-flow",
                            "job-trigger",
                            "log-check",
                            "manual-checkpoint"
                          ]
                        },
                        "target": {
                          "type": "string"
                        },
                        "command": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "url": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "route": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "expected_signal": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "required": {
                          "type": "boolean"
                        },
                        "evidence_types": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "stdout",
                              "exit-code",
                              "status-code",
                              "response-body",
                              "log-line",
                              "screenshot",
                              "trace",
                              "operator-note",
                              "artifact-link"
                            ]
                          }
                        },
                        "notes": {
                          "type": [
                            "string",
                            "null"
                          ]
                        }
                      }
                    }
                  },
                  "manual_checkpoints": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "id",
                        "label",
                        "reason",
                        "required_for_release",
                        "evidence_types"
                      ],
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "label": {
                          "type": "string"
                        },
                        "reason": {
                          "type": "string"
                        },
                        "required_for_release": {
                          "type": "boolean"
                        },
                        "evidence_types": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "operator-note",
                              "screenshot",
                              "screen-recording",
                              "audit-log",
                              "external-confirmation"
                            ]
                          }
                        },
                        "notes": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "fallback": {
                          "type": [
                            "string",
                            "null"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "validation_expectations": {
          "type": "object",
          "required": [
            "required",
            "surfaces_expected",
            "minimum_verdict",
            "preserve_invariants",
            "release_blockers"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "surfaces_expected": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "cli",
                  "api",
                  "browser",
                  "background-job"
                ]
              }
            },
            "minimum_verdict": {
              "type": "string",
              "enum": [
                "PASS",
                "PASS_WITH_FOLLOW_UP",
                "FAIL",
                "BLOCKED"
              ],
              "description": "Minimum acceptable runtime-validator verdict before Ship can present the change as releasable."
            },
            "preserve_invariants": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "release_blockers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "releasability": {
          "type": "object",
          "required": [
            "required",
            "status_when_satisfied",
            "required_evidence"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "status_when_satisfied": {
              "type": "string",
              "enum": [
                "READY",
                "READY_WITH_CONDITIONS",
                "BLOCKED"
              ],
              "description": "Expected releasability status once the required evidence set is satisfied."
            },
            "required_evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "kind",
                  "required"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "healthy-signal",
                      "failure-signal",
                      "monitoring-plan",
                      "rollback-trigger",
                      "rollback-procedure",
                      "owner",
                      "validation-window",
                      "follow-up"
                    ]
                  },
                  "required": {
                    "type": "boolean"
                  },
                  "description": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "conventions": {
      "type": "object",
      "properties": {
        "code_style": {
          "type": "object"
        },
        "git": {
          "type": "object"
        },
        "documentation": {
          "type": "object"
        }
      }
    },
    "harness_recommendations": {
      "type": "object",
      "description": "Recommended installation preset and optional capability packs derived during discovery",
      "properties": {
        "preset": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "starter",
            "standard",
            "full",
            null
          ]
        },
        "capability_packs": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "agent-intercom",
              "agent-engram",
              "backlogit",
              "browser-verification",
              "continuous-learning",
              "strict-safety",
              "release-observability",
              "adversarial-review",
              "graphtor-docs"
            ]
          }
        },
        "install_layers": {
          "type": "array",
          "description": "Explicit artifact-class layers the installer should compose, derived from preset, stack packs, runtime surfaces, and selected overlays",
          "items": {
            "type": "string",
            "enum": [
              "foundation",
              "instructions",
              "workflow",
              "review",
              "runtime",
              "backlog",
              "knowledge",
              "overlays"
            ]
          }
        },
        "recommendation_reasons": {
          "type": "object",
          "description": "Structured reasons explaining why discovery recommended a preset, capability packs, and install layers",
          "properties": {
            "preset": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "capability_packs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "item",
                  "because"
                ],
                "properties": {
                  "item": {
                    "type": "string",
                    "enum": [
                      "agent-intercom",
                      "agent-engram",
                      "backlogit",
                      "browser-verification",
                      "continuous-learning",
                      "strict-safety",
                      "release-observability",
                      "adversarial-review",
                      "graphtor-docs"
                    ]
                  },
                  "because": {
                    "type": "string"
                  },
                  "signals": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "install_layers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "item",
                  "because"
                ],
                "properties": {
                  "item": {
                    "type": "string",
                    "enum": [
                      "foundation",
                      "instructions",
                      "workflow",
                      "review",
                      "runtime",
                      "backlog",
                      "knowledge",
                      "overlays"
                    ]
                  },
                  "because": {
                    "type": "string"
                  },
                  "signals": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "agent_intercom": {
      "type": "object",
      "description": "Detected agent-intercom integration markers and recommendation state",
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "mcp_configured": {
          "type": "boolean"
        },
        "config_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instruction_markers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended": {
          "type": "boolean"
        }
      }
    },
    "agent_engram": {
      "type": "object",
      "description": "Detected agent-engram integration markers and recommendation state",
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "mcp_configured": {
          "type": "boolean"
        },
        "config_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instruction_markers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended": {
          "type": "boolean"
        }
      }
    },
    "graphtor_docs": {
      "type": "object",
      "description": "Detected graphtor-docs integration markers and recommendation state",
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "mcp_configured": {
          "type": "boolean"
        },
        "config_paths": {
          "type": "array",
          "description": "Paths to MCP and other non-sources config files found (normally .mcp.json; legacy editor-local MCP files may also be recorded when discovered)",
          "items": {
            "type": "string"
          }
        },
        "sources_path": {
          "type": "string",
          "description": "Path to the graphtor-docs sources configuration file (sources.yaml) that declares which paths, repos, and URLs to index"
        },
        "binary_path": {
          "type": [
            "string",
            "null"
          ],
          "description": "Resolved path to the graphtor-docs binary. Null when the binary is discovered via PATH or the default '.graphtor/bin/' location."
        },
        "embed_model_dir": {
          "type": [
            "string",
            "null"
          ],
          "description": "Resolved path to the local sentence-transformer embedding model directory used for offline vector search. Null when not detected; the installer defaults it to '<workspace_root>/.graphtor/models/all-MiniLM-L6-v2'."
        },
        "instruction_markers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended": {
          "type": "boolean"
        }
      }
    },
    "agent_native": {
      "type": "object",
      "description": "Detected agent-native or MCP-heavy product signals that justify a parity-focused reviewer persona",
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "mcp_sdk_present": {
          "type": "boolean"
        },
        "mcp_transport": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "stdio",
            "sse",
            "streamable-http",
            null
          ]
        },
        "agent_tooling_markers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "user_agent_parity_required": {
          "type": "boolean"
        },
        "recommended_reviewer": {
          "type": "boolean"
        }
      }
    },
    "copilot_review": {
      "type": "object",
      "description": "Configuration for the deterministic Copilot-review merge gate (P-018). Controls whether merge is held until Copilot review completes for the current HEAD and all Copilot-authored threads are resolved.",
      "properties": {
        "enforcement": {
          "type": "string",
          "description": "auto: detect engagement from per-PR Copilot signals (not-applicable when Copilot never engages). required: fail-closed even before Copilot is requested. disabled: gate is off.",
          "enum": [
            "auto",
            "required",
            "disabled"
          ],
          "default": "auto"
        },
        "max_wait_seconds": {
          "type": "integer",
          "description": "Bounded window the gate waits for an engaged reviewer to complete for the current HEAD before emitting REVIEW_TIMEOUT (still BLOCKS). 0 = single-shot check.",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "existing_harness": {
      "type": "object",
      "properties": {
        "has_harness": {
          "type": "boolean"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "backlog_tool": {
      "type": "object",
      "description": "Detected backlog management tool and its configuration",
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "tool_name": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "backlogit",
            "backlog-md",
            "manual",
            null
          ],
          "description": "When 'manual', no registry is expected. The harness installs a minimal backlog directory structure (queue/, archive/) without tool integration."
        },
        "directory": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool_type": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "mcp",
            "cli",
            "both",
            null
          ]
        },
        "mcp_registered": {
          "type": "boolean"
        },
        "cli_available": {
          "type": "boolean"
        },
        "config_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "registry_path": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to the backlog tool registry YAML"
        },
        "status_values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "suffix_map": {
          "type": [
            "object",
            "null"
          ],
          "description": "Work item type suffix mapping detected from backlog config (e.g., {feature: 'F', chore: 'C', task: 'T', shipment: 'S'})",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "vscode": {
      "type": "object",
      "description": "Detected VS Code workspace presence and user settings state",
      "properties": {
        "detected": {
          "type": "boolean",
          "description": "True when any VS Code signal (.vscode/, *.code-workspace, .vscode/settings.json) is found in the target workspace"
        },
        "user_settings_path": {
          "type": [
            "string",
            "null"
          ],
          "description": "Resolved absolute path to the VS Code user settings file for the current OS (e.g. C:\\Users\\alice\\AppData\\Roaming\\Code\\User\\settings.json on Windows). Null when the OS is unrecognised. Never uses ~ shorthand."
        },
        "has_agent_settings": {
          "type": "boolean",
          "description": "True when the VS Code user settings file already contains chat.agentFilesLocations, chat.agentSkillsLocations, or chat.promptFilesLocations entries pointing to the resolved autoharness home path"
        }
      }
    },
    "ai_environments": {
      "type": "object",
      "description": "Detected operator AI CLI/editor environments used by the scripted deploy path (deploy-harness.ps1 / deploy-harness.sh) to default its register phase.",
      "properties": {
        "detected": {
          "type": "array",
          "description": "Subset of AI environments detected on PATH or via workspace signals.",
          "items": {
            "type": "string",
            "enum": [
              "vscode",
              "copilot-cli",
              "claude",
              "codex"
            ]
          },
          "uniqueItems": true
        },
        "register_default": {
          "type": "string",
          "description": "The deploy-harness --register default: the primary detected environment, preferring an explicit operator choice, then the strongest detected CLI, then vscode, then copilot-cli.",
          "enum": [
            "vscode",
            "copilot-cli",
            "claude",
            "codex",
            "none"
          ]
        }
      }
    },
    "distribution": {
      "type": "object",
      "description": "Signals indicating that this workspace is a globally-distributed tool that ships agent definitions in its package. When present, the installer routes workflow agents to a local-only directory to prevent distribution leakage.",
      "properties": {
        "is_global_tool": {
          "type": "boolean",
          "description": "True when the workspace is a globally-distributed tool that ships agents in its package (e.g. via pyproject.toml force-include mappings to a wheel). When true and the target workspace equals autoharness_home, the installer enters self-install mode."
        },
        "global_agents_dir": {
          "type": [
            "string",
            "null"
          ],
          "description": "The directory where globally-distributed agents live and are included in the distribution package. Default: .github/agents. These agents are source-controlled and should never be overwritten by the workflow agent installer."
        },
        "local_agents_dir": {
          "type": [
            "string",
            "null"
          ],
          "description": "Override directory for local-only workflow agents (stage, ship) that must not leak into the distribution package. Default: .github/local-agents. This directory must NOT appear in any wheel force-include mapping."
        }
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "object",
      "description": "Detected development tools beyond language toolchain and build system",
      "properties": {
        "markdownlint": {
          "type": "boolean",
          "description": "True when markdownlint-cli is installed and available on PATH"
        },
        "markdownlint_config": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to existing markdownlint config file (.markdownlint.json, .markdownlint.yaml), or null if none found"
        }
      }
    },
    "drift_report": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": {
                "type": "string",
                "enum": [
                  "breaking",
                  "degrading",
                  "cosmetic",
                  "growth"
                ]
              },
              "description": {
                "type": "string"
              },
              "affected_artifacts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "checksum_scan": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "manifest_present": {
              "type": "boolean"
            },
            "ignore_file": {
              "type": [
                "string",
                "null"
              ]
            },
            "checked_artifacts": {
              "type": "integer",
              "minimum": 0
            },
            "missing_count": {
              "type": "integer",
              "minimum": 0
            },
            "user_modified_count": {
              "type": "integer",
              "minimum": 0
            },
            "ignored_count": {
              "type": "integer",
              "minimum": 0
            },
            "artifacts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "classification": {
                    "type": "string",
                    "enum": [
                      "missing",
                      "user-modified",
                      "unchanged",
                      "ignored"
                    ]
                  },
                  "manifest_checksum": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "current_checksum": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "reason": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "priority": {
                "type": "string",
                "enum": [
                  "P0",
                  "P1",
                  "P2",
                  "P3"
                ]
              },
              "summary": {
                "type": "string"
              },
              "related_artifacts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
