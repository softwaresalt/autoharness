{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workspace Profile",
  "description": "Schema for the workspace profile generated by the workspace-discovery skill",
  "type": "object",
  "required": ["schema_version", "generated_at", "workspace_path", "languages", "build", "test"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace_path": {
      "type": "string"
    },
    "languages": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "description": "The primary programming language of the workspace"
        },
        "secondary": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "frameworks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "build": {
      "type": "object",
      "required": ["tool", "command"],
      "properties": {
        "tool": { "type": "string" },
        "command": { "type": "string" }
      }
    },
    "test": {
      "type": "object",
      "required": ["runner", "command"],
      "properties": {
        "runner": { "type": "string" },
        "command": { "type": "string" },
        "directory": { "type": "string" }
      }
    },
    "lint": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "command": { "type": "string" }
      }
    },
    "format": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "command": { "type": "string" },
        "fix_command": { "type": "string" }
      }
    },
    "ci": {
      "type": "object",
      "properties": {
        "platform": { "type": "string" },
        "pipeline_steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quality_gates": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "structure": {
      "type": "object",
      "properties": {
        "source_layout": { "type": "string" },
        "test_layout": { "type": "string" },
        "doc_layout": { "type": "string" }
      }
    },
    "runtime_surfaces": {
      "type": "object",
      "description": "Runtime surfaces that may require post-build verification and operational closure",
      "properties": {
        "web_ui": { "type": "boolean" },
        "public_api": { "type": "boolean" },
        "background_jobs": { "type": "boolean" },
        "deployment_manifests": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "conventions": {
      "type": "object",
      "properties": {
        "code_style": { "type": "object" },
        "git": { "type": "object" },
        "documentation": { "type": "object" }
      }
    },
    "harness_recommendations": {
      "type": "object",
      "description": "Recommended installation preset and optional capability packs derived during discovery",
      "properties": {
        "preset": {
          "type": ["string", "null"],
          "enum": ["starter", "standard", "full", null]
        },
        "capability_packs": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["agent-intercom", "browser-verification", "strict-safety", "release-observability"]
          }
        }
      }
    },
    "agent_intercom": {
      "type": "object",
      "description": "Detected agent-intercom integration markers and recommendation state",
      "properties": {
        "detected": { "type": "boolean" },
        "mcp_configured": { "type": "boolean" },
        "config_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "instruction_markers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended": { "type": "boolean" }
      }
    },
    "existing_harness": {
      "type": "object",
      "properties": {
        "has_harness": { "type": "boolean" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "type": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "backlog_tool": {
      "type": "object",
      "description": "Detected backlog management tool and its configuration",
      "properties": {
        "detected": { "type": "boolean" },
        "tool_name": { "type": ["string", "null"], "enum": ["backlogit", "backlog-md", "manual", null] },
        "directory": { "type": ["string", "null"] },
        "tool_type": { "type": ["string", "null"], "enum": ["mcp", "cli", "both", null] },
        "mcp_registered": { "type": "boolean" },
        "cli_available": { "type": "boolean" },
        "config_path": { "type": ["string", "null"] },
        "registry_path": { "type": ["string", "null"], "description": "Path to the backlog tool registry YAML" },
        "status_values": { "type": "array", "items": { "type": "string" } },
        "features": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    },
    "drift_report": {
      "type": ["object", "null"],
      "properties": {
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": {
                "type": "string",
                "enum": ["breaking", "degrading", "cosmetic", "growth"]
              },
              "description": { "type": "string" },
              "affected_artifacts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
