{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workspace Profile",
  "description": "Schema for the workspace profile generated by the workspace-discovery skill",
  "type": "object",
  "required": ["schema_version", "generated_at", "workspace_path", "languages", "build", "test"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace_path": {
      "type": "string"
    },
    "languages": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "description": "The primary programming language of the workspace"
        },
        "version": {
          "type": ["string", "null"],
          "description": "Language version or edition detected from toolchain config (e.g., rust-toolchain.toml, package.json engines, .python-version)"
        },
        "secondary": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "frameworks": {
      "type": "object",
      "description": "Detected frameworks and specialized SDK integrations",
      "properties": {
        "list": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of detected frameworks (e.g., React, FastAPI, Cobra)"
        },
        "mcp_sdk": {
          "type": ["string", "null"],
          "description": "MCP SDK detected in dependencies (e.g., mcp-go, @modelcontextprotocol/sdk, mcp)"
        },
        "mcp_transport": {
          "type": ["string", "null"],
          "enum": ["stdio", "sse", "streamable-http", null],
          "description": "MCP transport mechanism detected when MCP SDK is present"
        }
      }
    },
    "primary_stack_pack": {
      "type": ["string", "null"],
      "description": "Primary normalized stack classification chosen from detected additive stack packs (for example web-app, api-service, background-worker, mcp-server, cli-tool, or library)"
    },
    "stack_packs": {
      "type": "array",
      "description": "Additive normalized stack classifications detected in the workspace and used to refine preset, layer, and overlay recommendations",
      "items": { "type": "string" }
    },
    "build": {
      "type": "object",
      "required": ["tool", "command"],
      "properties": {
        "tool": { "type": "string" },
        "command": { "type": "string" },
        "check_command": {
          "type": ["string", "null"],
          "description": "Fast compilation-only check command (no tests). Defaults to build.command if null. E.g., cargo check --all-targets, tsc --noEmit."
        }
      }
    },
    "test": {
      "type": "object",
      "required": ["runner", "command"],
      "properties": {
        "runner": { "type": "string" },
        "command": { "type": "string" },
        "directory": { "type": "string" }
      }
    },
    "lint": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "command": { "type": "string" }
      }
    },
    "format": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "command": { "type": "string" },
        "check_command": {
          "type": ["string", "null"],
          "description": "Read-only format check command (exits non-zero if formatting needed). Defaults to appending --check to format.command."
        },
        "fix_command": { "type": "string" }
      }
    },
    "ci": {
      "type": "object",
      "properties": {
        "platform": { "type": "string" },
        "pipeline_steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quality_gates": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "structure": {
      "type": "object",
      "properties": {
        "source_layout": { "type": "string" },
        "test_layout": { "type": "string" },
        "doc_layout": { "type": "string" }
      }
    },
    "runtime_surfaces": {
      "type": "object",
      "description": "Runtime surfaces that may require post-build verification and operational closure",
      "properties": {
        "web_ui": { "type": "boolean" },
        "public_api": { "type": "boolean" },
        "background_jobs": { "type": "boolean" },
        "browser_tooling": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Detected browser automation or browser QA tooling relevant to runtime verification"
        },
        "deployment_manifests": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "conventions": {
      "type": "object",
      "properties": {
        "code_style": { "type": "object" },
        "git": { "type": "object" },
        "documentation": { "type": "object" }
      }
    },
    "harness_recommendations": {
      "type": "object",
      "description": "Recommended installation preset and optional capability packs derived during discovery",
      "properties": {
        "preset": {
          "type": ["string", "null"],
          "enum": ["starter", "standard", "full", null]
        },
        "capability_packs": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["agent-intercom", "agent-engram", "backlogit", "browser-verification", "continuous-learning", "strict-safety", "release-observability", "adversarial-review"]
          }
        },
        "install_layers": {
          "type": "array",
          "description": "Explicit artifact-class layers the installer should compose, derived from preset, stack packs, runtime surfaces, and selected overlays",
          "items": {
            "type": "string",
            "enum": ["foundation", "instructions", "workflow", "review", "runtime", "backlog", "knowledge", "overlays"]
          }
        },
        "recommendation_reasons": {
          "type": "object",
          "description": "Structured reasons explaining why discovery recommended a preset, capability packs, and install layers",
          "properties": {
            "preset": {
              "type": "array",
              "items": { "type": "string" }
            },
            "capability_packs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["item", "because"],
                "properties": {
                  "item": {
                    "type": "string",
                    "enum": ["agent-intercom", "agent-engram", "backlogit", "browser-verification", "continuous-learning", "strict-safety", "release-observability", "adversarial-review"]
                  },
                  "because": { "type": "string" },
                  "signals": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            },
            "install_layers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["item", "because"],
                "properties": {
                  "item": {
                    "type": "string",
                    "enum": ["foundation", "instructions", "workflow", "review", "runtime", "backlog", "knowledge", "overlays"]
                  },
                  "because": { "type": "string" },
                  "signals": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "agent_intercom": {
      "type": "object",
      "description": "Detected agent-intercom integration markers and recommendation state",
      "properties": {
        "detected": { "type": "boolean" },
        "mcp_configured": { "type": "boolean" },
        "config_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "instruction_markers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended": { "type": "boolean" }
      }
    },
    "agent_engram": {
      "type": "object",
      "description": "Detected agent-engram integration markers and recommendation state",
      "properties": {
        "detected": { "type": "boolean" },
        "mcp_configured": { "type": "boolean" },
        "config_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "instruction_markers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended": { "type": "boolean" }
      }
    },
    "agent_native": {
      "type": "object",
      "description": "Detected agent-native or MCP-heavy product signals that justify a parity-focused reviewer persona",
      "properties": {
        "detected": { "type": "boolean" },
        "mcp_sdk_present": { "type": "boolean" },
        "mcp_transport": {
          "type": ["string", "null"],
          "enum": ["stdio", "sse", "streamable-http", null]
        },
        "agent_tooling_markers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "user_agent_parity_required": { "type": "boolean" },
        "recommended_reviewer": { "type": "boolean" }
      }
    },
    "existing_harness": {
      "type": "object",
      "properties": {
        "has_harness": { "type": "boolean" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "type": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "backlog_tool": {
      "type": "object",
      "description": "Detected backlog management tool and its configuration",
      "properties": {
        "detected": { "type": "boolean" },
        "tool_name": { "type": ["string", "null"], "enum": ["backlogit", "backlog-md", "manual", null], "description": "When 'manual', no registry is expected. The harness installs a minimal backlog directory structure (queue/, archive/) without tool integration." },
        "directory": { "type": ["string", "null"] },
        "tool_type": { "type": ["string", "null"], "enum": ["mcp", "cli", "both", null] },
        "mcp_registered": { "type": "boolean" },
        "cli_available": { "type": "boolean" },
        "config_path": { "type": ["string", "null"] },
        "registry_path": { "type": ["string", "null"], "description": "Path to the backlog tool registry YAML" },
        "status_values": { "type": "array", "items": { "type": "string" } },
        "features": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "suffix_map": {
          "type": ["object", "null"],
          "description": "Work item type suffix mapping detected from backlog config (e.g., {feature: 'F', chore: 'C', task: 'T', shipment: 'S'})",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "vscode": {
      "type": "object",
      "description": "Detected VS Code workspace presence and user settings state",
      "properties": {
        "detected": {
          "type": "boolean",
          "description": "True when any VS Code signal (.vscode/, *.code-workspace, .vscode/settings.json) is found in the target workspace"
        },
        "user_settings_path": {
          "type": ["string", "null"],
          "description": "Resolved absolute path to the VS Code user settings file for the current OS (e.g. C:\\Users\\alice\\AppData\\Roaming\\Code\\User\\settings.json on Windows). Null when the OS is unrecognised. Never uses ~ shorthand."
        },
        "has_agent_settings": {
          "type": "boolean",
          "description": "True when the VS Code user settings file already contains chat.agentFilesLocations, chat.agentSkillsLocations, or chat.promptFilesLocations entries pointing to the resolved autoharness home path"
        }
      }
    },
    "drift_report": {
      "type": ["object", "null"],
      "properties": {
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": {
                "type": "string",
                "enum": ["breaking", "degrading", "cosmetic", "growth"]
              },
              "description": { "type": "string" },
              "affected_artifacts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "checksum_scan": {
          "type": ["object", "null"],
          "properties": {
            "manifest_present": { "type": "boolean" },
            "ignore_file": { "type": ["string", "null"] },
            "checked_artifacts": { "type": "integer", "minimum": 0 },
            "missing_count": { "type": "integer", "minimum": 0 },
            "user_modified_count": { "type": "integer", "minimum": 0 },
            "ignored_count": { "type": "integer", "minimum": 0 },
            "artifacts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "classification": {
                    "type": "string",
                    "enum": ["missing", "user-modified", "unchanged", "ignored"]
                  },
                  "manifest_checksum": { "type": ["string", "null"] },
                  "current_checksum": { "type": ["string", "null"] },
                  "reason": { "type": ["string", "null"] }
                }
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "priority": {
                "type": "string",
                "enum": ["P0", "P1", "P2", "P3"]
              },
              "summary": { "type": "string" },
              "related_artifacts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
