              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "description": "Per-level sizing source map; unavailable/not_applicable preserves missing-source semantics."
            },
            "sizing_source_revisions": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "description": "Per-level planned-estimate revision captured at pre_execution."
