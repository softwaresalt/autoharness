      "pattern": "\\S",
      "description": "Stable event identifier; non-empty and non-whitespace."
    },
    "epoch_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 32,
          "maxLength": 32,
          "pattern": "^[0-9a-f]{32}$"
        },
        {
          "type": "null"
        }
      ],
      "description": "Parent ExecutionEpoch canonical UUID hex ID when known. This follows filename-safe epoch ID rules."
    },
    "parent_event_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Parent event ID for retries, fallbacks, or nested operations."
        },
        {
          "type": "null"
        }
      ],
      "description": "Parent event ID for retries, fallbacks, or nested operations."
    },
    "timestamp": {
      "type": "string",
      "description": "ISO-8601 event timestamp."
    },
    "workspace_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
