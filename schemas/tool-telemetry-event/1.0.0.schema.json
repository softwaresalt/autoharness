    },
    "commit_sha": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Commit correlation, or null when unavailable."
    },
    "session_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Session correlation, or null when unavailable."
    },
    "agent_role": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
