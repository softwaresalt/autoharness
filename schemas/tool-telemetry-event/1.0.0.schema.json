                {
                  "type": "null"
                }
              ],
              "description": "Known unique shipment task count, or null when membership is unavailable."
            },
            "shipment_manifest_size_histogram": {
              "type": "object",
              "description": "Shipment task count by XS/S/M/L/XL plus unsized; there is no unavailable bucket.",
              "additionalProperties": false,
              "properties": {
                "XS": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for XS."
                },
                "S": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for S."
                },
                "M": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for M."
                },
                "L": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for L."
                },
                "XL": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for XL."
                },
                "unsized": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for unsized."
                }
              }
            },
            "shipment_membership_hash": {
              "anyOf": [
                {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                {
                  "type": "null"
                }
              ],
              "description": "SHA-256 hash of the canonical unique shipment task ID set, or null when membership is unavailable."
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional immutable pre_execution work sizing snapshot."
