            "sizing_ruleset_versions": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "description": "Per-level ruleset or source contract version metadata."
            },
            "feature_planned_child_task_count": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Known unique feature child task count, or null when membership is unavailable."
                },
                {
                  "type": "null"
                }
              ],
              "description": "Known unique feature child task count, or null when membership is unavailable."
            },
            "feature_planned_child_size_histogram": {
              "type": "object",
              "description": "Feature child task count by XS/S/M/L/XL plus unsized; there is no unavailable bucket.",
              "additionalProperties": false,
              "properties": {
                "XS": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for XS."
                },
                "S": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for S."
                },
                "M": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for M."
                },
                "L": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for L."
                },
                "XL": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for XL."
                },
                "unsized": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Count for unsized."
                }
              }
            },
