{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/softwaresalt/autoharness/schemas/execution-epoch.schema.json",
  "title": "ExecutionEpoch",
  "description": "ExecutionEpoch v1.1 serialized epoch record. This schema describes root correlation fields including feature_id, token-economics fields, provenance maps, route/operation/outcome roll-ups, per-tool gap maps, and the nullable WorkSizingSnapshot payload. Null/unavailable values distinguish missing metrics from observed zero counts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "epoch_id",
    "task_id",
    "backlog_item_id",
    "timestamp",
    "route",
    "economics",
    "operations",
    "outcome"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1.0",
      "description": "ExecutionEpoch schema version."
    },
    "epoch_id": {
      "type": "string",
      "minLength": 32,
      "maxLength": 32,
      "pattern": "^[0-9a-f]{32}$",
      "description": "Canonical lowercase UUID hex execution epoch ID captured before task-close replay."
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S",
      "description": "Task ID for the task epoch."
    },
    "backlog_item_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S",
      "description": "Backlog work item ID; for task epochs this is the task_id."
    },
    "timestamp": {
      "type": "string",
      "description": "ISO-8601 epoch close timestamp."
    },
    "workspace_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Workspace correlation ID, or null when unavailable."
    },
    "session_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Agent/session correlation ID, or null when unavailable."
    },
    "agent_role": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Agent role correlation such as ship, or null when unavailable."
    },
    "phase": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Lifecycle phase correlation, or null when unavailable."
    },
    "feature_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Feature correlation ID supplied by backlogit/operator, or null when unavailable."
    },
    "shipment_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Shipment correlation ID supplied by backlogit/operator, or null when unavailable."
    },
    "branch": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Git branch correlation, or null when unavailable."
    },
    "commit_sha": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Git commit correlation, or null when unavailable."
    },
    "route": {
      "type": "object",
      "description": "RouteConfiguration payload: model route and route-kind roll-up fields.",
      "additionalProperties": false,
      "properties": {
        "models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Models used during the epoch."
        },
        "route_kinds": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "enum": [
                  "structural_graph",
                  "doc_index",
                  "backlog_index",
                  "intercom",
                  "raw_search",
                  "raw_read",
                  "none"
                ]
              },
              {
                "type": "string",
                "pattern": "^x-[a-z0-9-]+$"
              }
            ],
            "description": "Route kind value."
          },
          "description": "Route kinds used during the epoch for tool-offload reporting."
        },
        "primary_route_kind": {
          "anyOf": [
            {
              "oneOf": [
                {
                  "enum": [
                    "structural_graph",
                    "doc_index",
                    "backlog_index",
                    "intercom",
                    "raw_search",
                    "raw_read",
                    "none"
                  ]
                },
                {
                  "type": "string",
                  "pattern": "^x-[a-z0-9-]+$"
                }
              ],
              "description": "First/primary route kind derived from route_kinds when known, otherwise null."
            },
            {
              "type": "null"
            }
          ],
          "description": "First/primary route kind derived from route_kinds when known, otherwise null."
        }
      }
    },
    "economics": {
      "type": "object",
      "description": "EconomicPayload token, cost, duration, estimate, and provenance metrics. Null means unavailable; zero means an observed zero count.",
      "additionalProperties": false,
      "properties": {
        "input_tokens": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Input token consumption for the epoch."
            },
            {
              "type": "null"
            }
          ],
          "description": "Input token consumption for the epoch."
        },
        "output_tokens": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Output token generation for the epoch."
            },
            {
              "type": "null"
            }
          ],
          "description": "Output token generation for the epoch."
        },
        "cached_input_tokens": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Host-reported cached input tokens."
            },
            {
              "type": "null"
            }
          ],
          "description": "Host-reported cached input tokens."
        },
        "cumulative_input_tokens": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Final cumulative input-token total; do not sum across turns."
            },
            {
              "type": "null"
            }
          ],
          "description": "Final cumulative input-token total; do not sum across turns."
        },
        "cumulative_output_tokens": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Final cumulative output-token total; do not sum across turns."
            },
            {
              "type": "null"
            }
          ],
          "description": "Final cumulative output-token total; do not sum across turns."
        },
        "context_tokens_before": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Context tokens before the epoch/turn when available."
            },
            {
              "type": "null"
            }
          ],
          "description": "Context tokens before the epoch/turn when available."
        },
        "context_tokens_after": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Context tokens after the epoch/turn when available."
            },
            {
              "type": "null"
            }
          ],
          "description": "Context tokens after the epoch/turn when available."
        },
        "context_area_tokens": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Estimated area-under-context tokens for the epoch."
            },
            {
              "type": "null"
            }
          ],
          "description": "Estimated area-under-context tokens for the epoch."
        },
        "avoided_read_estimated_tokens": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Estimated tokens avoided through tool offload."
            },
            {
              "type": "null"
            }
          ],
          "description": "Estimated tokens avoided through tool offload."
        },
        "tool_output_estimated_tokens": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Estimated tokens introduced by tool output."
            },
            {
              "type": "null"
            }
          ],
          "description": "Estimated tokens introduced by tool output."
        },
        "cogs_usd": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ],
          "description": "Cost of goods sold in USD for the epoch."
        },
        "duration_seconds": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ],
          "description": "Wall-clock duration in seconds."
        },
        "metric_sources": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "host_reported",
              "estimated",
              "derived",
              "unavailable",
              "not_applicable",
              "host",
              "backlogit",
              "operator"
            ]
          },
          "description": "Map from populated metric field name to its source. Use unavailable or not_applicable for legacy or unavailable metrics so zero counts and nullable estimates never imply precision."
        },
        "metric_quality": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "observed",
              "estimated",
              "derived",
              "unavailable",
              "not_applicable"
            ]
          },
          "description": "Map from populated metric field name to metric quality. Use unavailable or not_applicable for legacy/unavailable values so estimates and zero counts never imply false precision."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "input_tokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "input_tokens"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "input_tokens"
                ]
              },
              "metric_quality": {
                "required": [
                  "input_tokens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "output_tokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "output_tokens"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "output_tokens"
                ]
              },
              "metric_quality": {
                "required": [
                  "output_tokens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "cached_input_tokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "cached_input_tokens"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "cached_input_tokens"
                ]
              },
              "metric_quality": {
                "required": [
                  "cached_input_tokens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "cumulative_input_tokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "cumulative_input_tokens"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "cumulative_input_tokens"
                ]
              },
              "metric_quality": {
                "required": [
                  "cumulative_input_tokens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "cumulative_output_tokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "cumulative_output_tokens"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "cumulative_output_tokens"
                ]
              },
              "metric_quality": {
                "required": [
                  "cumulative_output_tokens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "context_tokens_before": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "context_tokens_before"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "context_tokens_before"
                ]
              },
              "metric_quality": {
                "required": [
                  "context_tokens_before"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "context_tokens_after": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "context_tokens_after"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "context_tokens_after"
                ]
              },
              "metric_quality": {
                "required": [
                  "context_tokens_after"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "context_area_tokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "context_area_tokens"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "context_area_tokens"
                ]
              },
              "metric_quality": {
                "required": [
                  "context_area_tokens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "avoided_read_estimated_tokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "avoided_read_estimated_tokens"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "avoided_read_estimated_tokens"
                ]
              },
              "metric_quality": {
                "required": [
                  "avoided_read_estimated_tokens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "tool_output_estimated_tokens": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "tool_output_estimated_tokens"
            ]
          },
          "then": {
            "properties": {
              "metric_sources": {
                "required": [
                  "tool_output_estimated_tokens"
                ]
              },
              "metric_quality": {
                "required": [
                  "tool_output_estimated_tokens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "cogs_usd": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": [
