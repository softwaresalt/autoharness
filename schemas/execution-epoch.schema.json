                "required": [
                  "duration_seconds"
                ]
              }
            }
          }
        }
      ]
    },
    "operations": {
      "type": "object",
      "description": "OperationalReality payload: CLI/tool usage, route counts, offload counts, and expected-vs-observed gap maps.",
      "additionalProperties": false,
      "properties": {
        "cli_tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "CLI tools used during the epoch."
        },
        "tool_surfaces": {
          "type": "array",
          "items": {
            "enum": [
              "mcp",
              "cli",
              "shell",
              "builtin",
              "api",
              "unknown"
            ]
          },
          "description": "Tool surfaces observed during the epoch."
        },
        "retrieval_packs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Capability packs used for retrieval/offload."
        },
        "route_kind_counts": {
          "type": "object",
          "description": "Counts by route kind for epoch-level offload reporting.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "description": "Count for this key; zero means an observed zero count."
          }
        },
        "routed_lookup_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Count of routed/indexed lookups."
            },
            {
              "type": "null"
            }
          ],
          "description": "Count of routed/indexed lookups."
        },
        "raw_file_read_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Count of raw file reads."
            },
            {
              "type": "null"
            }
          ],
          "description": "Count of raw file reads."
        },
        "raw_search_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Count of raw grep/glob/search fallbacks."
            },
            {
              "type": "null"
            }
          ],
          "description": "Count of raw grep/glob/search fallbacks."
        },
        "avoided_file_read_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Estimated count of raw file reads avoided by offload."
            },
            {
              "type": "null"
            }
          ],
          "description": "Estimated count of raw file reads avoided by offload."
        },
        "tool_output_bytes": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Bytes returned by tools after redaction/truncation."
            },
            {
              "type": "null"
            }
          ],
          "description": "Bytes returned by tools after redaction/truncation."
        },
        "expected_tool_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Total expected tool invocations."
            },
            {
              "type": "null"
            }
          ],
          "description": "Total expected tool invocations."
        },
        "observed_expected_tool_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Observed invocations of expected tools."
            },
            {
              "type": "null"
            }
          ],
          "description": "Observed invocations of expected tools."
        },
        "missing_expected_tool_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Expected tool invocations not observed."
            },
            {
              "type": "null"
            }
          ],
          "description": "Expected tool invocations not observed."
        },
        "expected_tool_counts": {
          "type": "object",
          "description": "Per-tool expected invocation counts.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "description": "Count for this key; zero means an observed zero count."
          }
        },
        "observed_tool_counts": {
          "type": "object",
          "description": "Per-tool observed expected-tool invocation counts.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "description": "Count for this key; zero means an observed zero count."
          }
        },
        "missing_expected_tool_counts": {
          "type": "object",
          "description": "Per-tool expected-minus-observed gap counts.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "description": "Count for this key; zero means an observed zero count."
          }
        },
        "degraded_tool_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "Routing/offload diagnostic count for tools invoked through degraded fallback behavior."
            },
            {
              "type": "null"
            }
          ],
          "description": "Routing/offload diagnostic count for tools invoked through degraded fallback behavior."
        },
        "stale_or_unavailable_index_count": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
