{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Harness Manifest 0.9.0",
  "description": "Legacy installed-harness manifest contract for autoharness v0.9.0 workspaces.",
  "type": "object",
  "required": ["schema_version", "installed_at", "autoharness_version", "profile_hash", "primitives_installed", "artifacts"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.9.0",
      "description": "Legacy schema version for autoharness v0.9.0"
    },
    "installed_at": {
      "type": "string",
      "format": "date-time"
    },
    "tuned_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "autoharness_version": {
      "type": "string"
    },
    "profile_hash": {
      "type": "string"
    },
    "primitives_installed": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      }
    },
    "capability_packs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "agent-intercom",
          "agent-engram",
          "backlogit",
          "browser-verification",
          "continuous-learning",
          "strict-safety",
          "release-observability",
          "adversarial-review",
          "circuit-breaker",
          "concurrency"
        ]
      }
    },
    "capability_pack_overlays": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pack", "overlay_targets", "verification_checks"],
        "properties": {
          "pack": {
            "type": "string",
            "enum": [
              "agent-intercom",
              "agent-engram",
              "backlogit",
              "browser-verification",
              "continuous-learning",
              "strict-safety",
              "release-observability",
              "adversarial-review",
              "circuit-breaker",
              "concurrency"
            ]
          },
          "overlay_targets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "verification_checks": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "primitive", "template", "checksum"],
        "properties": {
          "path": { "type": "string" },
          "primitive": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "template": { "type": "string" },
          "checksum": { "type": "string" }
        }
      }
    }
  }
}