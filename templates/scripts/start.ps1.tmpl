# Agent CLI Startup Script — {{PROJECT_NAME}}
#
# Sets workspace-local directories so that AI agent state (memories,
# checkpoints, database) is scoped to this workspace and git-visible.
#
# Activate the section matching your AI CLI tool.
# To switch tools, comment out the active section and uncomment another.
#
# Generated by autoharness. Re-run install or tune to regenerate.

# ── GitHub Copilot CLI ──────────────────────────────────────────────────────
# COPILOT_HOME redirects the Copilot CLI database and memory to a workspace-
# local directory. This keeps agent state visible in git and isolated per
# project rather than shared across all workspaces.
#
# Requires: gh CLI (authenticated), copilot on PATH or set COPILOT_EXE_PATH
# in .autoharness/config.yaml under ai_tools.copilot_cli.exe_path before
# re-running autoharness install or tune.
#
$env:COPILOT_HOME = ".\.copilot"
# $env:ENGRAM_DATA_DIR = ".\.engram"   # Uncomment when the agent-engram capability pack is active
$env:GITHUB_TOKEN = (gh auth token)
& "{{COPILOT_EXE_PATH}}"

# ── Claude Code ─────────────────────────────────────────────────────────────
# Uncomment to run Claude Code with workspace-local state directories.
# CLAUDE_HOME redirects Claude's config and history to the workspace.
# Verify that your installed version of claude supports this env variable.
#
# $env:CLAUDE_HOME = ".\.claude"
# claude

# ── OpenAI Codex / Agents ────────────────────────────────────────────────────
# Uncomment to run Codex with a workspace-local API key file.
#
# $env:OPENAI_API_KEY = (Get-Content .openai-token -Raw).Trim()
# codex
