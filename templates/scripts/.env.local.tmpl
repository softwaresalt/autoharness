# Local environment for {{PROJECT_NAME}} — secrets and per-developer overrides.
#
# This file is GITIGNORED. Do not commit. autoharness generates it once and
# never overwrites it, so your secrets and machine-specific values survive
# re-installs and tunes.
#
# The workspace startup scripts (start.ps1 / start.sh) load this file before
# launching your AI CLI tool. Each KEY=VALUE line is exported as a process
# environment variable, but only when that variable is not already set in the
# environment. A single pair of matching surrounding quotes is stripped.
#
# Loader pattern (PowerShell), for reference:
#   Get-Content .env.local | ForEach-Object {
#     if ($_ -match '^\s*([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.+?)\s*$') {
#       Set-Item -Path "env:$($matches[1])" -Value $matches[2]
#     }
#   }
#
# Or use python-dotenv if you prefer (installable via pip):
#   from dotenv import load_dotenv; load_dotenv(".env.local")

# Absolute path to this workspace root. Provides a stable, machine-specific
# anchor for agents and tooling that need the workspace location. Update this
# if you move or clone the workspace to a different path.
workspace_root={{WORKSPACE_ROOT}}
