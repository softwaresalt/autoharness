# Generated by autoharness | Template: ci/ci.yml.tmpl
#
# Language-agnostic CI workflow implementing the unified CI + local-gating
# primitive (P-019). Three-job shape:
#   1. changes           — lightweight, ALWAYS runs, fail-closed path detection.
#   2. {{CI_EXPENSIVE_JOB_NAME}} — the expensive test/build gate; runs only when
#                          the fail-closed `changes` job detected a code change.
#   3. {{CI_REQUIRED_CHECK_NAME}} — the always-running aggregation gate. This is
#                          the ONLY job a branch ruleset should require: it treats
#                          a skipped expensive job as OK and fails only when a
#                          needed job actually failed or was cancelled.
#
# Regular PR/push CI is Linux-only ({{CI_RUNNER_OS}}); cross-OS verification is
# deferred to release-tag workflows. To run every PR across macOS/Windows,
# replace `runs-on: {{CI_RUNNER_OS}}` with a matrix strategy (see the OS-matrix
# escape hatch documented in templates/ci/README.md).
#
# Actions are SHA-pinned. Refreshing pins is a periodic maintenance chore, not a
# per-change concern.
name: CI

on:
  push:
    branches:
      - main
  pull_request:
    branches:
      - main

permissions:
  contents: read

concurrency:
  group: ci-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # Lightweight always-running gate: decide whether the expensive pipeline needs
  # to run. Because this job always runs, a status is always reported while the
  # costly job below is skipped for changes that touch only docs/backlog files.
  #
  # predicate-quantifier: 'every' requires ALL patterns to match per file, so the
  # '!' negations actually exclude docs/markdown/backlog. Under the default 'some'
  # the leading '**' alone would mark every file matched and the negations would
  # never take effect (see dorny/paths-filter README) — a fail-OPEN bug. 'every'
  # makes any code/config/unknown-type change fail CLOSED into the expensive gate.
  changes:
    name: detect code changes
    runs-on: {{CI_RUNNER_OS}}
    permissions:
      contents: read
      pull-requests: read
    outputs:
      code: ${{ steps.filter.outputs.code }}
    steps:
      - name: Checkout
        uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10 # v6.0.3
        with:
          persist-credentials: false
      - name: Detect code changes
        id: filter
        uses: dorny/paths-filter@d1c1ffe0248fe513906c8e24db8ea791d46f8590 # v3.0.3
        with:
          predicate-quantifier: 'every'
          filters: |
            # Denylist: match any changed file that is NOT pure docs/backlog
            # state, so a code/config change can never silently skip the gate.
            code:
              - '**'
{{CI_DOCS_ONLY_PATHS}}

  # Expensive test/build gate. Runs only when the fail-closed `changes` job
  # detected a code/config change. Execution is gated SOLELY on the path result
  # so a code change can never bypass validation via the PR title — a `docs:` or
  # `chore:` title cannot skip the tests when code actually changed. Docs/backlog
  # -only PRs skip this job because `changes` reports `code == 'false'`.
  #
  # The job ID (`expensive`) is a fixed, valid GitHub Actions identifier; the
  # human-facing check context is `name: {{CI_EXPENSIVE_JOB_NAME}}`, which may
  # contain spaces/slashes. Job IDs may not, so the two are decoupled.
  expensive:
    name: {{CI_EXPENSIVE_JOB_NAME}}
    needs: changes
    if: needs.changes.outputs.code == 'true'
    runs-on: {{CI_RUNNER_OS}}
    steps:
{{CI_SETUP_STEPS}}
      - name: Lint
        run: {{LINT_COMMAND}}
      - name: Format check
        run: {{FORMAT_CHECK_COMMAND}}
      - name: Typecheck
        run: {{TYPECHECK_COMMAND}}
      - name: Test
        run: {{TEST_COMMAND}}
      - name: Build check
        run: {{BUILD_CHECK_COMMAND}}

  # Always-reporting aggregation gate. REQUIRE THIS job in branch protection
  # instead of the guarded expensive job: when the expensive job is skipped for a
  # docs-only PR, GitHub reports it "skipped" — which a required
  # check treats as not-successful and would block the merge. This gate always
  # runs and passes unless a needed job actually failed or was cancelled.
  #
  # The job ID (`ci-gate`) is a fixed, valid GitHub Actions identifier. The
  # required-check context that a branch ruleset matches on is the reported
  # `name: {{CI_REQUIRED_CHECK_NAME}}`, which may contain spaces (e.g. `ci gate`)
  # — set {{CI_REQUIRED_CHECK_NAME}} to the exact name the ruleset already
  # requires so no ruleset edit is needed.
  ci-gate:
    name: {{CI_REQUIRED_CHECK_NAME}}
    if: always()
    needs: [changes, expensive]
    runs-on: {{CI_RUNNER_OS}}
    steps:
      - name: Verify no required job failed
        run: |
          results="${{ needs.changes.result }} ${{ needs.expensive.result }}"
          echo "job results: $results"
          for r in $results; do
            if [ "$r" = "failure" ] || [ "$r" = "cancelled" ]; then
              echo "::error::A required job did not succeed: $r"
              exit 1
            fi
          done
          echo "All required jobs passed or were intentionally skipped."
