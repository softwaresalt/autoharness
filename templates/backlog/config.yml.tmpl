# Backlog Configuration
# Generated by autoharness

project: "{{PROJECT_NAME}}"
version: "1.0.0"

# Task ID format
id_format: "task-{feature}.{sequence}"

# Status values
statuses:
  - "To Do"
  - "In Progress"
  - "Done"
  - "Blocked"

# Priority values
priorities:
  - "P0"
  - "P1"
  - "P2"
  - "P3"

# Labels
labels:
  - "harness-ready"
  - "blocked"
  - "needs-review"
  - "deliberation-outcome"
  - "spike"
