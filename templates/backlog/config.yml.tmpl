# Backlog Configuration
# Generated by autoharness

project: "{{PROJECT_NAME}}"
version: "1.0.0"

# Directory layout
#   {{BACKLOG_DIRECTORY}}/
#     queue/            — Active work items (features, tasks, spikes, deliberations, bugs)
#       .stash.md       — Parked ideas and deferred outcomes
#     archive/          — Completed and archived work items

# Work item ID format
# Hierarchy is visible at the file system level through the ID structure:
#   Level 1: {prefix}-{NNN}                  (epics / features)
#   Level 2: {prefix}-{NNN}.{NNN}            (sub-epics / tasks)
#   Level 3: {prefix}-{NNN}.{NNN}.{NNN}      (subtasks)
# Files are named: {prefix}-{NNN}-{slug}.md (or {prefix}-{NNN}.{NNN}-{slug}.md, etc.)
#
# Prefix map — default work item type prefixes.
# These are single or two-letter codes used to prefix work item filenames
# in the queue directory (e.g., F-001-user-auth.md, T-001.001-add-login.md).
# When using backlogit, the installer reads prefixes from backlogit's project
# config YAML and overrides these defaults during installation.
prefix_map:
  feature: "F"
  task: "T"
  spike: "S"
  deliberation: "D"
  bug: "B"
  epic: "E"
  subtask: "ST"

# Status values
statuses:
  - "To Do"
  - "In Progress"
  - "Done"
  - "Blocked"

# Priority values
priorities:
  - "P0"
  - "P1"
  - "P2"
  - "P3"

# Labels
labels:
  - "harness-ready"
  - "blocked"
  - "needs-review"
  - "deliberation-outcome"
  - "spike"

# Long-lived knowledge artifacts are stored in docs/, not in the backlog.
# See docs/compound/, docs/plans/, docs/decisions/, docs/memory/, docs/closure/.
