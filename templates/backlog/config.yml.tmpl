# Backlog Configuration
# Generated by autoharness

project: "{{PROJECT_NAME}}"
version: "1.0.0"

# Directory layout
#   {{BACKLOG_DIRECTORY}}/
#     queue/            — Active work items (features, chores, tasks, spikes, deliberations, bugs)
#       .stash.md       — Parked ideas and deferred outcomes
#     archive/          — Completed and archived work items

# Work item ID format
# Hierarchy is visible at the file system level through the ID structure:
#   Level 1: {prefix}-{NNN}                  (features / chores / epics)
#   Level 2: {prefix}-{NNN}.{NNN}            (sub-epics / tasks)
#   Level 3: {prefix}-{NNN}.{NNN}.{NNN}      (subtasks)
# Files are named: {prefix}-{NNN}-{slug}.md (or {prefix}-{NNN}.{NNN}-{slug}.md, etc.)
#
# Prefix map — work item type prefixes resolved from .autoharness/config.yaml.
# These are single or two-letter codes used to prefix work item filenames
# in the queue directory (e.g., F-001-user-auth.md, C-002-python-312-migration.md,
# T-001.001-add-login.md).
prefix_map:
  feature: "{{PREFIX_FEATURE}}"
  chore: "{{PREFIX_CHORE}}"
  task: "{{PREFIX_TASK}}"
  spike: "{{PREFIX_SPIKE}}"
  deliberation: "{{PREFIX_DELIBERATION}}"
  bug: "{{PREFIX_BUG}}"
  epic: "{{PREFIX_EPIC}}"
  subtask: "{{PREFIX_SUBTASK}}"

# Status values
statuses:
  - "{{STATUS_QUEUED}}"
  - "{{STATUS_ACTIVE}}"
  - "{{STATUS_DONE}}"
  - "{{STATUS_BLOCKED}}"

# Priority values
priorities:
  - "P0"
  - "P1"
  - "P2"
  - "P3"

# Labels
labels:
  - "harness-ready"
  - "blocked"
  - "needs-review"
  - "deliberation-outcome"
  - "spike"

# Long-lived knowledge artifacts are stored in {{DOCS_ROOT}}/, not in the backlog.
# See {{DOCS_COMPOUND}}/, {{DOCS_PLANS}}/, {{DOCS_DECISIONS}}/, {{DOCS_MEMORY}}/, {{DOCS_CLOSURE}}/.
