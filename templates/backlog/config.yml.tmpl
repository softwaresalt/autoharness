# Backlog Configuration
# Generated by autoharness

project: "{{PROJECT_NAME}}"
version: "1.0.0"

# Directory layout
#   {{BACKLOG_DIRECTORY}}/
#     queue/            — Active work items (features, chores, tasks, spikes, deliberations, bugs)
#       .stash.md       — Parked ideas and deferred outcomes
#     archive/          — Completed and archived work items

# Work item ID format
# Hierarchy is visible at the file system level through the ID structure:
#   Level 1: {NNN}-{suffix}                        (features / chores / epics)
#   Level 2: {NNN}.{NNN}-{suffix}                  (sub-epics / tasks)
#   Level 3: {NNN}.{NNN}.{NNN}-{suffix}            (subtasks)
# Files are named: {NNN}-{suffix}-{slug}.md (or {NNN}.{NNN}-{suffix}-{slug}.md, etc.)
#
# Suffix map — work item type suffixes resolved from .autoharness/config.yaml.
# These are single or two-letter codes appended as type suffixes to work item IDs
# in the queue directory (e.g., 001-F-user-auth.md, 002-C-python-312-migration.md,
# 001.001-T-add-login.md).
suffix_map:
  feature: "{{SUFFIX_FEATURE}}"
  chore: "{{SUFFIX_CHORE}}"
  task: "{{SUFFIX_TASK}}"
  spike: "{{SUFFIX_SPIKE}}"
  deliberation: "{{SUFFIX_DELIBERATION}}"
  bug: "{{SUFFIX_BUG}}"
  epic: "{{SUFFIX_EPIC}}"
  subtask: "{{SUFFIX_SUBTASK}}"
  shipment: "{{SUFFIX_SHIPMENT}}"

# Status values
statuses:
  - "{{STATUS_QUEUED}}"
  - "{{STATUS_ACTIVE}}"
  - "{{STATUS_DONE}}"
  - "{{STATUS_BLOCKED}}"

# Priority values
priorities:
  - "P0"
  - "P1"
  - "P2"
  - "P3"

# Labels
labels:
  - "harness-ready"
  - "blocked"
  - "needs-review"
  - "deliberation-outcome"
  - "spike"

# Long-lived knowledge artifacts are stored in {{DOCS_ROOT}}/, not in the backlog.
# See {{DOCS_COMPOUND}}/, {{DOCS_PLANS}}/, {{DOCS_DECISIONS}}/, {{DOCS_MEMORY}}/, {{DOCS_CLOSURE}}/.
