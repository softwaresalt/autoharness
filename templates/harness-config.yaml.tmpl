# autoharness Configuration
#
# Resolved harness configuration for this workspace.
# Written by autoharness install; updated by autoharness tune.
# Operator edits to this file are preserved on re-install and tuning.
#
# Schema: schemas/harness-config.schema.json

schema_version: "1.0.0"

# Installation preset: starter | standard | full
preset: {{INSTALL_PRESET}}

# Additive stack classification used for composition
primary_stack_pack: {{PRIMARY_STACK_PACK}}
stack_packs: {{STACK_PACKS_YAML}}

# Explicit artifact-class layers selected for installation
install_layers: {{INSTALL_LAYERS_YAML}}

# Capability packs enabled for this workspace
capability_packs: {{CAPABILITY_PACKS_YAML}}

# Backlog tool configuration
backlog:
  tool: {{BACKLOG_TOOL_NAME}}
  directory: {{BACKLOG_DIRECTORY}}
  suffix_map:
    feature: "{{SUFFIX_FEATURE}}"
    chore: "{{SUFFIX_CHORE}}"
    task: "{{SUFFIX_TASK}}"
    spike: "{{SUFFIX_SPIKE}}"
    deliberation: "{{SUFFIX_DELIBERATION}}"
    bug: "{{SUFFIX_BUG}}"
    epic: "{{SUFFIX_EPIC}}"
    subtask: "{{SUFFIX_SUBTASK}}"
    shipment: "{{SUFFIX_SHIPMENT}}"

# Long-lived knowledge artifact directories
docs:
  root: {{DOCS_ROOT}}
  subdirectories:
    compound: {{DOCS_COMPOUND_DIR}}
    plans: {{DOCS_PLANS_DIR}}
    decisions: {{DOCS_DECISIONS_DIR}}
    memory: {{DOCS_MEMORY_DIR}}
    closure: {{DOCS_CLOSURE_DIR}}
    design_docs: {{DOCS_DESIGN_DOCS_DIR}}
    product_specs: {{DOCS_PRODUCT_SPECS_DIR}}

# Optional continuous-learning capability-pack configuration
continuous_learning:
  directory: "{{CONTINUOUS_LEARNING_DIR}}"
  capture_hooks: {{CONTINUOUS_LEARNING_CAPTURE_HOOKS}}
  environment_adapter: "{{CONTINUOUS_LEARNING_ENVIRONMENT_ADAPTER}}"
  promotion_threshold: {{CONTINUOUS_LEARNING_PROMOTION_THRESHOLD}}

# Optional strict-safety capability-pack configuration
strict_safety:
  enabled: {{STRICT_SAFETY_ENABLED}}
  require_approval_for:
    - destructive

# Model routing preferences (map tiers to model identifiers and per-tier config)
model_routing:
  tier1:
    model: {{MODEL_ROUTING_TIER1}}              # Fast/cheap: memory, docs, compaction (e.g., gpt-5.4-mini)
    reasoning_effort: "{{TIER_1_REASONING_EFFORT}}"  # Leave empty to use model default
    model_provider: "{{TIER_1_PROVIDER}}"       # e.g., openai, anthropic — leave empty for default
    model_family: "{{TIER_1_FAMILY}}"           # Resolved into Tier 1 agent frontmatter
  tier2:
    model: {{MODEL_ROUTING_TIER2}}              # Standard: orchestration, code, review (e.g., claude-sonnet-4.6)
    reasoning_effort: "{{TIER_2_REASONING_EFFORT}}"
    model_provider: "{{TIER_2_PROVIDER}}"
    model_family: "{{TIER_2_FAMILY}}"
  tier3:
    model: {{MODEL_ROUTING_TIER3}}              # Frontier: planning, architecture, analysis (e.g., claude-opus-4.6)
    reasoning_effort: "{{TIER_3_REASONING_EFFORT}}"
    model_provider: "{{TIER_3_PROVIDER}}"
    model_family: "{{TIER_3_FAMILY}}"
  orchestrator:
    model_family: "{{ORCHESTRATOR_FAMILY}}"     # Orchestrator model override (default: gpt-5.4)
    reasoning_effort: "{{ORCHESTRATOR_REASONING_EFFORT}}"
    model_provider: "{{ORCHESTRATOR_PROVIDER}}"

# AI CLI tool startup configuration
# Resolves {{COPILOT_EXE_PATH}} in the generated start.ps1 and start.sh scripts.
# Set exe_path to the full path if copilot is not on PATH.
ai_tools:
  copilot_cli:
    exe_path: "{{COPILOT_EXE_PATH}}"  # Default: "copilot" (expects it on PATH)
                                      # Example: "C:\\Tools\\ghcpcli\\copilot.exe"

# Optional browser-automation capability configuration (used when browser-verification is enabled)
browser:
  cli: "{{BROWSER_CLI}}"                    # Default: "agent-browser"
  headless_flag: "{{BROWSER_HEADLESS_FLAG}}" # Default: "--headless"

# Optional iterative-experiment skill configuration
experiments:
  branch_prefix: "{{EXPERIMENT_BRANCH_PREFIX}}"  # Default: "experiment/"
  results_dir: "{{EXPERIMENT_RESULTS_DIR}}"       # Default: "docs/experiments"

# Explicit template variable overrides applied during install/tune (use sparingly —
# prefer fixing the workspace setup over overriding discovery results)
overrides: {{HARNESS_OVERRIDES_YAML}}
